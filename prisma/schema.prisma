// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  
}

datasource db {
  provider = "postgresql"
  url = env("DATABASE_URL")
}

//---------------------------- HUESPED ----------------------

model Huesped {
  id        String   @id @default(uuid())
  nombres    String   
  apellidos  String
  numeroDocumento Int
  fechaNacimiento DateTime?
  ingreso DateTime?
  salida DateTime?

  productos Producto[] @relation("productos")

  habitacionId String?
  habitacion Habitacion? @relation("habitacionHuesped", fields: [habitacionId], references: [id] )

  responsableId String?
  responsable Huesped? @relation("huespedAcompanantes", fields: [responsableId], references: [id])

  acompanantes Huesped[] @relation("huespedAcompanantes")
  

}

//---------------------------- HABITACION -------------------

enum Tipo {
  Junior
  Presidencial
  Junior_decorada
  Presidencial_decorada
}

model Habitacion {
  id String @id @default(uuid())
  numeroHabitacion Int @unique
  capacidad Int
  tipo Tipo
  precio Int
  ocupado Boolean
  jacuzzi Boolean
  aireAcondicionado Boolean

  huespedes Huesped[] @relation("habitacionHuesped")

}

//---------------------------- PRODUCTO ---------------------

enum Categoria {
  Bebidas
  Comidas
  Sexual
}

model Producto {
  id String @id @default(uuid())
  nombreProducto String
  descripcionProducto String
  categoria Categoria
  precio Int
  existencia Int
  cantidadSolicitada Int?

  huespedId String?
  huesped Huesped? @relation("productos", fields: [huespedId], references: [id])
}